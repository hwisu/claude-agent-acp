{
  "name": "@hwisu/claude-agent-acp",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.3.167",
  "description": "ACP-compatible coding agent powered by the Claude Agent SDK. Fork of @agentclientprotocol/claude-agent-acp with first-class ACP terminal-capability routing.",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "claude-agent-acp": "dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist/",
    "!dist/tests/",
    "README.md",
    "LICENSE",
    "NOTICE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "aube run build && aube run start",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "aube run lint && aube run format:check",
    "test": "vitest",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "sync-sdk-version": "node script/sync-sdk-version.mjs",
    "prepublishOnly": "aube run sync-sdk-version && aube run build"
  },
  "packageManager": "aube@1.10.4",
  "keywords": [
    "claude",
    "acp",
    "agent",
    "anthropic",
    "typescript",
    "sdk",
    "code"
  ],
  "homepage": "https://github.com/hwisu/claude-agent-acp#readme",
  "bugs": {
    "url": "https://github.com/hwisu/claude-agent-acp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hwisu/claude-agent-acp.git"
  },
  "author": "hwisu (fork of Zed Industries' @agentclientprotocol/claude-agent-acp)",
  "license": "Apache-2.0",
  "dependencies": {
    "@agentclientprotocol/sdk": "0.25.0",
    "@anthropic-ai/claude-agent-sdk": "0.3.167",
    "@anthropic-ai/sdk": "0.101.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.6.0",
    "prettier": "3.8.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
